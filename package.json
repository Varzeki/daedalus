{
  "name": "daedalus",
  "version": "2.0.0",
  "description": "DAEDALUS Terminal for Elite Dangerous",
  "scripts": {
    "build": "npm run build:client && npm run build:app && npm run build:service && npm run build:verify && npm run build:package",
    "build:verify": "node scripts/build/build-verify.js",
    "build:client": "cd src/client && next build && next export -o ../../build/client",
    "build:app": "node scripts/build/build-app.js",
    "build:service": "node scripts/build/build-service.js",
    "build:package": "node scripts/build/build-package.js",
    "build:standalone": "npm run build:client && node scripts/build/build-standalone.js",
    "build:clean": "node scripts/build/build-clean.js",
    "build:assets": "node scripts/build/build-assets.js && npm run build:data",
    "build:data": "node scripts/build/build-data.js",
    "build:debug": "npm run build:client && npm run build:debug:app && npm run build:debug:service",
    "build:debug:app": "node scripts/build/build-app.js --debug",
    "build:debug:service": "node scripts/build/build-service.js --debug",
    "start": "npm run dev",
    "clean": "npm run build:clean",
    "dev": "node src/service/main.js --dev",
    "lint": "npm run lint:go && npm run lint:javascript",
    "lint:go": "go fmt src/app/main.go",
    "lint:javascript": "npx standard --fix",
    "compress-images": "npx imagemin src/client/public/images/** --out-dir src/client/public/images/"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.2",
    "csvtojson": "^2.0.10",
    "fs-extra": "^10.0.0",
    "makensis": "^1.1.1",
    "next": "^12.1.5",
    "nodemon": "^2.0.15",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-hot-toast": "^2.2.0",
    "resedit": "^3.0.2",
    "standard": "^17.1.2",
    "svgtofont": "^3.12.9",
    "to-ico": "^1.0.1",
    "upx": "^1.0.6",
    "wikitext2plaintext": "^0.1.0",
    "xml2js": "^0.6.2"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "async-retry": "^1.3.3",
    "axios": "^1.15.0",
    "connect": "^3.7.0",
    "dotenv": "^10.0.0",
    "glob": "^13.0.6",
    "http-proxy": "^1.18.1",
    "nedb-promises": "^5.0.2",
    "one-time": "^0.0.4",
    "say": "^0.16.0",
    "serve-static": "^1.14.1",
    "ws": "^8.2.3",
    "yargs": "^17.2.1"
  },
  "pkg": {
    "assets": [
      "build/client/**/*",
      "src/service/data/**/*",
      "src/service/lib/system-media-thumbnail-helper.cs",
      "src/service/lib/system-audio-meter-helper.cs"
    ]
  },
  "engines": {
    "npm": ">=9.6.7",
    "node": ">=20"
  }
}
